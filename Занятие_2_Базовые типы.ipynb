def find_posit(n, c, k):
    entrance = (k - 1) // (n * c) + 1
    floor = ((k - 1) % (n * c)) // n + 1
    return entrance, floor

def visualize_test(n, c, k, expected):
    actual = find_posit(n, c, k)
    
    print(f"\nТест: N={n} (кв/этаж), C={c} (этажей), K={k} (квартира)")
    print(f"Квартир в подъезде: {n} × {c} = {n*c}")
    
    if actual == expected:
        print(f"✅ Результат: подъезд {actual[0]}, этаж {actual[1]}")
        
        # Детализация расчета
        print(f"\nДетализация:")
        print(f"  1. (K-1) // (N×C) + 1 = ({k}-1) // ({n}×{c}) + 1 = {k-1} // {n*c} + 1 = {(k-1)//(n*c)} + 1 = {actual[0]}")
        print(f"  2. ((K-1) % (N×C)) // N + 1 = (({k}-1) % {n*c}) // {n} + 1 = {((k-1)%(n*c))} // {n} + 1 = {((k-1)%(n*c))//n} + 1 = {actual[1]}")
    else:
        print(f"❌ Ошибка!")
        print(f"  Ожидалось: подъезд {expected[0]}, этаж {expected[1]}")
        print(f"  Получено:  подъезд {actual[0]}, этаж {actual[1]}")

# Основные тесты
test_cases = [
    (3, 5, 14, (1, 5)),
    (3, 5, 23, (2, 3)),
    (8, 10, 240, (3, 10)),
    (3, 2, 14, (3, 1)),
    (3, 5, 58, (4, 5))
]

print("=" * 50)
print("ВИЗУАЛИЗАЦИЯ ТЕСТОВ ДЛЯ ФУНКЦИИ find_posit")
print("=" * 50)

for n, c, k, expected in test_cases:
    visualize_test(n, c, k, expected)

print("\n" + "=" * 50)
print("Все тесты завершены!")
